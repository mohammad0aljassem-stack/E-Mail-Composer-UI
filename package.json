{
  "name": "e-mail-composer-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db": "bash scripts/test-db.sh",
    "contract:verify": "node scripts/verify-contract-manifest.mjs",
    "gen:types": "bash scripts/gen-types.sh",
    "audit:prod": "pnpm audit --prod --audit-level high"
  },
  "dependencies": {
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.1.0",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.110.2",
    "@tiptap/core": "2.27.2",
    "@tiptap/extension-link": "2.27.2",
    "@tiptap/pm": "2.27.2",
    "@tiptap/react": "2.27.2",
    "@tiptap/starter-kit": "2.27.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sanitize-html": "2.17.6"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "supabase": "2.109.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
