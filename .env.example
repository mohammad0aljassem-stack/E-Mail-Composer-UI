# --- Feature flags (fail closed: everything disabled by default) ----------

# Phase 1 composer surface (/composer-lab and /api/composer/render).
# Set to "true" locally to enable. Any other value disables it.
NEXT_PUBLIC_COMPOSER_V1_ENABLED=false

# Phase 2 draft lifecycle surface (/w/[workspaceId]/drafts pages and the
# /api/workspaces/** routes). Set to "true" locally to enable.
NEXT_PUBLIC_DRAFT_LIFECYCLE_V1_ENABLED=false

# --- Supabase (public values only) -----------------------------------------

# Project URL and PUBLISHABLE key (sb_publishable_...). These are public by
# design; all authorization happens through Auth sessions + RLS.
# NEVER put a service-role or secret key in this application — the UI runs
# entirely as the authenticated user. There is intentionally no
# SUPABASE_SERVICE_ROLE_KEY variable here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
